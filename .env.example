##############################################################################
#  Zastra — Environment Variables Reference
#
#  LOCAL DEV: copy this file to .env and fill in values.
#             Never commit .env to git (it's in .gitignore).
#
#  RENDER PROD: set these in the Render dashboard under each service's
#               "Environment" tab. The render.yaml handles auto-wiring
#               of DATABASE_URL, REDIS_URL, and PYTHON_API_BASE_URL.
##############################################################################

# ─── Java Backend ─────────────────────────────────────────────────────────────

# A random 64+ character string. Generate with:
#   openssl rand -base64 64
JWT_SECRET=REPLACE_WITH_A_REAL_SECRET_KEY_AT_LEAST_64_CHARS

# Local dev: uses H2 in-memory (set in application.properties, no override needed)
# Render prod: auto-injected from managed PostgreSQL — do not set manually
# DATABASE_URL=jdbc:postgresql://localhost:5432/devforge

# Postgres local dev (only used by docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_local_pw
POSTGRES_DB=devforge

# Spring profile — use 'prod' on Render, leave blank for local H2 dev
SPRING_PROFILES_ACTIVE=prod

# CORS — comma-separated list of allowed frontend origins
# Local dev: not needed (defaults to localhost:5173,5174,5175)
# Render prod: set to your frontend URL
ALLOWED_ORIGINS=https://zastra-frontend.onrender.com

# ─── Kafka (Upstash) ──────────────────────────────────────────────────────────
# Get these from https://console.upstash.com/kafka after creating a cluster.
# Local dev: leave commented out to use local Kafka via docker-compose.
KAFKA_BOOTSTRAP_SERVERS=your-cluster.upstash.io:9092
KAFKA_API_KEY=your_upstash_kafka_api_key
KAFKA_API_SECRET=your_upstash_kafka_api_secret

# ─── Python Scraper ───────────────────────────────────────────────────────────
# GitHub Personal Access Token for GitHub API scraping.
# Create at: https://github.com/settings/tokens (read:user scope)
GITHUB_TOKEN=ghp_your_github_pat_here

# URL of the Python scraper — auto-injected by Render; set for local dev
PYTHON_API_BASE_URL=http://localhost:8000

# ─── Frontend ─────────────────────────────────────────────────────────────────
# Set in Render Static Site env vars (or in ZastraFrontend/.env.local for dev)
# Local dev: not needed (falls back to http://localhost:8080 in api.js)
VITE_API_URL=https://zastra-backend.onrender.com
